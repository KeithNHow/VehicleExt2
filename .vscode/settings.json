{
    "al.enableCodeAnalysis": true,
    "al.codeAnalyzers": [
        "${CodeCop}",
        "${PerTenantExtensionCop}",
        "${UICop}"
    ],
    "[al]": {
        "editor.wordBasedSuggestions": "off",
        "editor.suggestSelection": "first",
        "editor.formatOnSave": true
    },
    "al.ruleSetPath": "./.vscode/ruleset.json",
    "al.backgroundCodeAnalysis": false,
    "al.enableCodeActions": false,
    "al.incrementalBuild": true,
    "al.compilationOptions": 
    {
        "generateReportLayout": true
    },
    "alOutline.codeCleanupActions": [
        "AddToolTips",
        "FixKeywordsCase",
        "FixIdentifiersCase",
        "SortVariables",
        "AddApplicationAreas",
        "SortTableFields",
        "AddMissingParentheses",
        "RemoveBeginEnd",
        "RemoveUnusedVariables"
    ],
    "editor.codeLens": false,

    "CRS.DisableDefaultAlSnippets": false,
    "CRS.OnSaveAlFileAction": "Rename",
    "CRS.FileNamePattern": "<ObjectName>.<ObjectTypeShortPascalCase>.al",
    "CRS.FileNamePatternExtensions": "<ObjectName>.<ObjectTypeShortPascalCase>.al",
    "CRS.FileNamePatternPageCustomizations": "<ObjectName>.<ObjectTypeShortPascalCase>.al",
    "workbench.colorCustomizations": {
    "editorError.foreground": "#be0101", 
    "editorWarning.foreground": "#dceb06"
    }
}